page {
  --primary: #1E5D75;
  --secondary: #2FA7A1;
  --green: #6CC37D;
  --orange: #FFB14E;
  --bg: #F5F7F6;
  --white: #FFFFFF;
  --text: #2C3E3A;
  --text-secondary: #7A8B85;
  --text-light: #A8B8B2;
  --border: #E8ECEA;
  --shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 24rpx rgba(0,0,0,0.06);
  --radius: 16rpx;
  --radius-lg: 24rpx;
  font-family: -apple-system,BlinkMacSystemFont,'PingFang SC','Helvetica Neue',sans-serif;
  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}

.flex{display:flex}.flex-center{display:flex;align-items:center}
.flex-between{display:flex;align-items:center;justify-content:space-between}
.flex-1{flex:1}.flex-wrap{flex-wrap:wrap}
.gap-8{gap:8rpx}.gap-12{gap:12rpx}.gap-16{gap:16rpx}.gap-24{gap:24rpx}
.text-center{text-align:center}
.text-secondary{color:var(--text-secondary)}
.text-light{color:var(--text-light)}
.text-primary{color:var(--primary)}
.text-orange{color:var(--orange)}
.text-green{color:var(--green)}
.font-bold{font-weight:700}
.font-22{font-size:22rpx}.font-24{font-size:24rpx}
.font-26{font-size:26rpx}.font-28{font-size:28rpx}
.font-32{font-size:32rpx}.font-36{font-size:36rpx}.font-40{font-size:40rpx}
.mt-8{margin-top:8rpx}.mt-16{margin-top:16rpx}.mt-24{margin-top:24rpx}
.mb-16{margin-bottom:16rpx}.mb-24{margin-bottom:24rpx}
.p-24{padding:24rpx}.p-32{padding:32rpx}
.px-24{padding-left:24rpx;padding-right:24rpx}

.card{
  background:var(--white);
  border-radius:var(--radius-lg);
  box-shadow:var(--shadow);
  overflow:hidden;
}
.card-padded{
  background:var(--white);
  border-radius:var(--radius-lg);
  padding:24rpx;
  box-shadow:var(--shadow);
}
.tag{
  display:inline-block;padding:4rpx 16rpx;
  border-radius:20rpx;font-size:22rpx;font-weight:500;
}
.tag-primary{background:rgba(30,93,117,0.08);color:var(--primary)}
.tag-green{background:rgba(108,195,125,0.12);color:#4a9a5a}
.tag-orange{background:rgba(255,177,78,0.12);color:#e09a30}
.tag-cyan{background:rgba(47,167,161,0.08);color:var(--secondary)}

.status-tag{
  display:inline-block;padding:6rpx 20rpx;
  border-radius:20rpx;font-size:22rpx;font-weight:600;
}
.status-registering{
  background:linear-gradient(135deg,rgba(108,195,125,0.15),rgba(47,167,161,0.1));
  color:var(--secondary)
}
.status-upcoming{background:rgba(255,177,78,0.12);color:#e09a30}
.status-finished{background:rgba(0,0,0,0.05);color:var(--text-light)}

.avatar{
  width:72rpx;height:72rpx;border-radius:50%;
  background:linear-gradient(135deg,var(--primary),var(--secondary));
  display:flex;align-items:center;justify-content:center;
  color:white;font-size:28rpx;font-weight:700;flex-shrink:0;
}
.avatar-sm{width:56rpx;height:56rpx;font-size:22rpx}
.avatar-lg{width:96rpx;height:96rpx;font-size:36rpx}

.btn{
  display:flex;align-items:center;justify-content:center;
  height:80rpx;border-radius:40rpx;font-size:28rpx;font-weight:600;
}
.btn-primary{background:linear-gradient(135deg,var(--primary),#1a4a5e);color:white}
.btn-secondary{background:linear-gradient(135deg,var(--secondary),#248a85);color:white}
.btn-outline{background:transparent;border:2rpx solid var(--primary);color:var(--primary)}
.btn-ghost{background:rgba(30,93,117,0.06);color:var(--primary)}
.btn-sm{height:56rpx;padding:0 24rpx;border-radius:28rpx;font-size:24rpx}
.btn-orange{background:linear-gradient(135deg,var(--orange),#f59e3a);color:white}

.divider{height:16rpx;background:var(--bg)}
.empty-state{padding:80rpx 0;text-align:center}
.empty-icon{font-size:80rpx;margin-bottom:16rpx}
.empty-text{font-size:26rpx;color:var(--text-light)}
