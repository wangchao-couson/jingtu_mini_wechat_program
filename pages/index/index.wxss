.index-page { padding-bottom: 40rpx; }

.nav-bar {
  background: linear-gradient(135deg, var(--primary), #1a4a5e);
  padding-bottom: 24rpx;
}
.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 32rpx 0;
}
.nav-brand { display: flex; align-items: center; gap: 12rpx; }
.nav-logo { width: 48rpx; height: 48rpx; border-radius: 12rpx; }
.nav-title { font-size: 36rpx; font-weight: 700; color: white; letter-spacing: 4rpx; }
.nav-subtitle { font-size: 22rpx; color: rgba(255,255,255,0.7); }

.greeting-card {
  margin: -16rpx 24rpx 24rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 1;
}
.greeting-hello { font-size: 32rpx; font-weight: 700; }
.greeting-sub { font-size: 24rpx; color: var(--text-secondary); margin-top: 6rpx; }

.section { margin: 0 24rpx 24rpx; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: 700; }
.section-more { font-size: 24rpx; color: var(--secondary); }

.event-scroll { width: 100%; }
.event-scroll-inner { display: flex; gap: 16rpx; padding-bottom: 4rpx; }
.event-mini-card { width: 340rpx; flex-shrink: 0; background: var(--white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
.event-mini-cover { width: 100%; height: 180rpx; }
.event-mini-info { padding: 16rpx 20rpx; }
.event-mini-title { font-size: 28rpx; font-weight: 600; line-height: 1.3; margin-bottom: 6rpx; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.event-mini-meta { font-size: 22rpx; color: var(--text-secondary); margin-bottom: 10rpx; }
.event-mini-bottom { display: flex; align-items: center; justify-content: space-between; }
.event-mini-spots { font-size: 22rpx; color: var(--text-light); }

.moments-list { background: var(--white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
.moment-item { display: flex; align-items: flex-start; gap: 16rpx; padding: 20rpx 24rpx; }
.moment-item + .moment-item { border-top: 1rpx solid var(--border); }
.moment-text { flex: 1; font-size: 26rpx; line-height: 1.5; }
.moment-name { font-weight: 600; color: var(--primary); margin-right: 4rpx; }
.moment-target { font-weight: 500; }
.moment-time { font-size: 22rpx; color: var(--text-light); margin-top: 2rpx; }

.photo-grid { display: flex; flex-wrap: wrap; gap: 8rpx; }
.photo-item { width: calc(33.33% - 6rpx); border-radius: var(--radius); overflow: hidden; position: relative; background: var(--border); }
.photo-img { width: 100%; height: 200rpx; }
.photo-meta { position: absolute; bottom: 0; left: 0; right: 0; padding: 16rpx 12rpx 8rpx; background: linear-gradient(transparent, rgba(0,0,0,0.55)); color: white; font-size: 20rpx; display: flex; justify-content: space-between; }

.anno-list { background: var(--white); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow); }
.anno-item { display: flex; gap: 12rpx; padding: 20rpx 24rpx; font-size: 24rpx; line-height: 1.5; }
.anno-item + .anno-item { border-top: 1rpx solid var(--border); }
.anno-dot { color: var(--orange); font-weight: 700; }
.anno-time { font-size: 22rpx; color: var(--text-light); margin-top: 4rpx; }