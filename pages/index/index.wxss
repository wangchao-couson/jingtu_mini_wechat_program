.stories-page{padding-bottom:40rpx;background:var(--bg);min-height:100vh}

/* Nav - clean white */
.stories-nav{background:#fff;padding:0 28rpx;display:flex;align-items:center;justify-content:space-between;height:88rpx;border-bottom:1rpx solid var(--border-light)}
.nav-left{display:flex;align-items:center;gap:10rpx}
.nav-logo{width:40rpx;height:40rpx;border-radius:10rpx}
.nav-name{font-size:32rpx;font-weight:700;color:var(--text);letter-spacing:2rpx}
.nav-tagline{font-size:22rpx;color:var(--text-light)}

.greeting{margin:20rpx 24rpx;background:var(--card);border-radius:var(--radius-xl);padding:24rpx 28rpx;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:18rpx}
.greeting-right{flex:1}
.greeting-hi{font-size:30rpx;font-weight:700;display:block}
.greeting-sub{font-size:24rpx;color:var(--text-secondary);margin-top:4rpx;display:block}

.sec-head{display:flex;align-items:center;justify-content:space-between;margin:24rpx 28rpx 14rpx}
.sec-title{font-size:30rpx;font-weight:700;color:var(--text)}
.sec-more{font-size:24rpx;color:var(--primary);font-weight:500}

.story-card{margin:0 24rpx 18rpx;background:var(--card);border-radius:var(--radius-xl);overflow:hidden;box-shadow:var(--shadow);display:block;text-decoration:none;color:inherit}
.story-cover{width:100%;height:210rpx}
.story-body{padding:20rpx 24rpx 22rpx}
.story-month{font-size:20rpx;color:var(--primary);font-weight:600;letter-spacing:2rpx;margin-bottom:8rpx}
.story-title{font-size:30rpx;font-weight:700;line-height:1.3;margin-bottom:4rpx;color:var(--text)}
.story-subtitle{font-size:24rpx;color:var(--text-secondary);margin-bottom:10rpx;line-height:1.4}
.story-meta{font-size:22rpx;color:var(--text-light);margin-bottom:12rpx}
.story-faces{display:flex;align-items:center;margin-bottom:12rpx}
.story-face{width:30rpx;height:30rpx;border-radius:50%;background:linear-gradient(135deg,var(--primary),#4F8CFF);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13rpx;font-weight:600;border:2rpx solid var(--card);margin-left:-7rpx}
.story-face:first-child{margin-left:0}
.story-face-more{width:30rpx;height:30rpx;border-radius:50%;background:var(--border);color:var(--text-secondary);display:flex;align-items:center;justify-content:center;font-size:13rpx;border:2rpx solid var(--card);margin-left:-7rpx}
.story-quote{font-size:24rpx;color:var(--text-secondary);line-height:1.5;border-left:3rpx solid var(--accent);padding-left:14rpx}

.story-intro{padding:34rpx 28rpx 14rpx}
.story-intro-kicker{font-size:20rpx;color:var(--accent);font-weight:900;letter-spacing:4rpx}
.story-intro-title{font-size:58rpx;font-weight:900;line-height:1.1;color:var(--text);margin-top:8rpx}
.story-intro-text{font-size:26rpx;color:var(--text-secondary);margin-top:8rpx}
.memory-card{margin:18rpx 24rpx 28rpx;background:var(--card);border-radius:26rpx;overflow:hidden;box-shadow:var(--shadow-md);border:1rpx solid rgba(232,225,212,.8)}
.memory-copy{padding:28rpx 28rpx 22rpx}
.memory-section{font-size:22rpx;color:var(--accent);font-weight:900;margin-bottom:12rpx}
.memory-title{font-size:38rpx;font-weight:900;line-height:1.15;color:var(--text)}
.memory-subtitle{font-size:26rpx;color:var(--text-secondary);line-height:1.5;margin-top:10rpx}
.memory-meta{font-size:22rpx;color:var(--text-light);margin-top:12rpx}
.memory-link{font-size:24rpx;color:var(--primary);font-weight:900;margin-top:16rpx}
.memory-img{width:100%;height:330rpx}
.memory-quote{padding:22rpx 28rpx 28rpx;font-size:27rpx;line-height:1.7;color:var(--text-secondary)}
.timeline-card{margin:8rpx 24rpx 28rpx;background:var(--card);border-radius:24rpx;padding:26rpx 28rpx;box-shadow:var(--shadow);border:1rpx solid rgba(232,225,212,.8)}
.timeline-title{font-size:30rpx;font-weight:900;margin-bottom:12rpx}
.timeline-row{display:flex;align-items:center;gap:18rpx;padding:18rpx 0;color:var(--text-secondary);font-weight:800}
.timeline-row view{height:2rpx;background:var(--border);flex:1}
