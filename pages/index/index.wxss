.stories-page{padding-bottom:40rpx}
.nav-bar{background:linear-gradient(160deg,var(--deep),#0a1f28);padding-bottom:20rpx}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:12rpx 28rpx 0}
.nav-brand{display:flex;align-items:center;gap:10rpx}
.nav-logo{width:44rpx;height:44rpx;border-radius:10rpx}
.nav-name{font-size:34rpx;font-weight:700;color:#fff;letter-spacing:4rpx}
.nav-tagline{font-size:22rpx;color:rgba(255,255,255,0.55);letter-spacing:2rpx}

.greeting{margin:24rpx;background:var(--card);border-radius:var(--radius-lg);padding:24rpx 28rpx;box-shadow:var(--shadow-md);display:flex;align-items:center;gap:18rpx}
.greeting-right{flex:1}
.greeting-hi{font-size:30rpx;font-weight:700;display:block}
.greeting-sub{font-size:24rpx;color:var(--gray);margin-top:4rpx;display:block}

.sec-head{display:flex;align-items:center;justify-content:space-between;margin:28rpx 28rpx 16rpx}
.sec-title{font-size:32rpx;font-weight:700;letter-spacing:1rpx}
.sec-more{font-size:24rpx;color:var(--teal);font-weight:500}

.story-card{margin:0 24rpx 20rpx;background:var(--card);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow);display:block;text-decoration:none;color:inherit}
.story-cover{width:100%;height:220rpx}
.story-body{padding:20rpx 24rpx 22rpx}
.story-month{font-size:20rpx;color:var(--teal);font-weight:600;letter-spacing:2rpx;text-transform:uppercase;margin-bottom:8rpx}
.story-title{font-size:32rpx;font-weight:700;line-height:1.3;margin-bottom:4rpx;color:var(--ink)}
.story-subtitle{font-size:24rpx;color:var(--gray);margin-bottom:10rpx;line-height:1.4}
.story-meta{font-size:22rpx;color:var(--light);margin-bottom:12rpx}
.story-faces{display:flex;align-items:center;margin-bottom:12rpx}
.story-face{width:32rpx;height:32rpx;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--mint));color:#fff;display:flex;align-items:center;justify-content:center;font-size:14rpx;font-weight:600;border:2rpx solid var(--card);margin-left:-8rpx}
.story-face:first-child{margin-left:0}
.story-face-more{width:32rpx;height:32rpx;border-radius:50%;background:var(--fog);color:var(--gray);display:flex;align-items:center;justify-content:center;font-size:14rpx;border:2rpx solid var(--card);margin-left:-8rpx}
.story-quote{font-size:24rpx;color:var(--gray);line-height:1.5;border-left:3rpx solid var(--amber);padding-left:14rpx;font-style:italic}