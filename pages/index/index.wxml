<view class="stories-page">
  <view class="jt-top" style="padding-top:{{statusBarHeight + 16}}px">
    <view class="jt-brand">京途</view>
    <view class="jt-line">{{dailyLine}}</view>
  </view>

  <view class="story-intro">
    <view class="story-intro-kicker">STORIES</view>
    <view class="story-intro-title">故事</view>
    <view class="story-intro-text">不是首页，是一本慢慢翻开的相册。</view>
  </view>

  <view wx:if="{{stories.length > 0}}">
    <view wx:for="{{stories}}" wx:key="id" class="memory-card">
      <view class="memory-copy">
        <view class="memory-section">{{item.section}}</view>
        <view class="memory-title">{{item.title}}</view>
        <view class="memory-subtitle">{{item.subtitle}}</view>
        <view class="memory-meta">{{item.meta}}</view>
        <view class="memory-link">查看故事</view>
      </view>
      <image src="{{item.cover}}" mode="aspectFill" class="memory-img"/>
      <view class="memory-quote">“{{item.quote}}”</view>
    </view>
  </view>

  <view class="timeline-card">
    <view class="timeline-title">故事时间轴</view>
    <view class="timeline-row" wx:for="{{months}}" wx:key="*this">
      <text>{{item}}</text>
      <view></view>
    </view>
  </view>

  <view style="height:40rpx"></view>
</view>
