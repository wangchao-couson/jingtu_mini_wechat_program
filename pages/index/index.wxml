<view class="index-page">
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-brand">
        <image class="nav-logo" src="/assets/logo.png" mode="aspectFit"></image>
        <text class="nav-title">京途</text>
      </view>
      <view class="nav-subtitle">活动日历 · 照片墙 · 通讯录</view>
    </view>
  </view>

  <view class="greeting-card">
    <view class="avatar avatar-lg">{{userInitial}}</view>
    <view class="greeting-text">
      <view class="greeting-hello">{{greeting}}，京途同学 👋</view>
      <view class="greeting-sub">今天宜出门，宜相遇，宜在路上</view>
    </view>
  </view>

  <view class="section" wx:if="{{recentEvents.length > 0}}">
    <view class="section-header">
      <text class="section-title">🏔️ 近期活动</text>
      <navigator url="/pages/events/events" class="section-more">全部 →</navigator>
    </view>
    <scroll-view scroll-x class="event-scroll" show-scrollbar="{{false}}">
      <view class="event-scroll-inner">
        <navigator
          wx:for="{{recentEvents}}"
          wx:key="id"
          url="/pages/event-detail/event-detail?id={{item.id}}"
          class="event-mini-card"
        >
          <image src="{{item.cover}}" mode="aspectFill" class="event-mini-cover"></image>
          <view class="event-mini-info">
            <view class="event-mini-title">{{item.title}}</view>
            <view class="event-mini-meta">{{item.date}} · {{item.location}}</view>
            <view class="event-mini-bottom">
              <text class="status-tag status-{{item.status}}">
                {{item.status === 'registering' ? '招募中' : item.status === 'upcoming' ? '即将开始' : '已结束'}}
              </text>
              <text class="event-mini-spots">{{item.currentParticipants}}/{{item.maxParticipants}}人</text>
            </view>
          </view>
        </navigator>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">📡 同学动态</text>
    </view>
    <view class="moments-list">
      <view class="moment-item" wx:for="{{moments}}" wx:key="index">
        <view class="avatar avatar-sm">{{item.user[0]}}</view>
        <view class="moment-text">
          <text class="moment-name">{{item.user}}</text>
          <text>{{item.action}}</text>
          <text class="moment-target">「{{item.target}}」</text>
          <view class="moment-time">{{item.time}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{photos.length > 0}}">
    <view class="section-header">
      <text class="section-title">📸 精选照片</text>
    </view>
    <view class="photo-grid">
      <view class="photo-item" wx:for="{{photos}}" wx:key="id" wx:if="{{index < 6}}">
        <image src="{{item.url}}" mode="aspectFill" class="photo-img"></image>
        <view class="photo-meta">
          <text class="photo-event">{{item.event}}</text>
          <text class="photo-user">by {{item.user}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{announcements.length > 0}}">
    <view class="section-header">
      <text class="section-title">📢 社区公告</text>
    </view>
    <view class="anno-list">
      <view class="anno-item" wx:for="{{announcements}}" wx:key="id">
        <text class="anno-dot">•</text>
        <view class="flex-1">
          <text>{{item.text}}</text>
          <view class="anno-time">{{item.time}}</view>
        </view>
      </view>
    </view>
  </view>

  <view style="height: 40rpx;"></view>
</view>