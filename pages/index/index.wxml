<view class="stories-page">
  <view class="stories-nav" style="padding-top:{{statusBarHeight}}px">
    <view class="nav-left"><image class="nav-logo" src="/assets/logo.png" mode="aspectFit"/><text class="nav-name">京途</text></view>
    <text class="nav-tagline">同学录</text>
  </view>

  <view class="greeting">
    <view class="avatar avatar-lg">{{userInitial}}</view>
    <view class="greeting-right">
      <text class="greeting-hi">{{greeting}}，京途同学</text>
      <text class="greeting-sub">你和 {{companionCount}} 位同学一起走过 {{totalKm}} 公里</text>
    </view>
  </view>

  <view class="slogan-banner">
    <text class="slogan-text">和<text class="slogan-highlight">有趣的人</text>，一起去探索<text class="slogan-highlight">更广阔的世界</text></text>
  </view>

  <view class="sec-head"><text class="sec-title">共同的故事</text><navigator url="/pages/events/events" class="sec-more">全部 →</navigator></view>

  <view wx:if="{{stories.length > 0}}">
    <navigator wx:for="{{stories}}" wx:key="id" url="/pages/event-detail/event-detail?id={{item.id}}" class="story-card">
      <image src="{{item.cover}}" mode="aspectFill" class="story-cover"/>
      <view class="story-body">
        <view class="story-month">{{item.month}}</view>
        <view class="story-title">{{item.title}}</view>
        <view class="story-subtitle">{{item.subtitle}}</view>
        <view class="story-meta">{{item.date}} · {{item.location}} · {{item.currentParticipants}}人同行</view>
        <view class="story-faces">
          <view class="story-face" wx:for="{{item.faceList}}" wx:key="*this" wx:for-item="f">{{f}}</view>
          <view class="story-face-more" wx:if="{{item.currentParticipants > item.faceList.length}}">+{{item.currentParticipants - item.faceList.length}}</view>
        </view>
        <view class="story-quote" wx:if="{{item.quote}}">"{{item.quote}}"</view>
      </view>
    </navigator>
  </view>
  <view class="empty-state" wx:else><view class="empty-icon">📖</view><view class="empty-text">还没有故事，去发现页看看吧</view></view>

  <view style="height:40rpx"></view>
</view>