.sd-page{min-height:100vh;background:var(--bg-main);padding-bottom:120rpx;color:#fff}
.sd-hero{height:560rpx;position:relative;overflow:hidden;background:#111}
.sd-hero-img{width:100%;height:100%}
.sd-mask{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,.12),rgba(0,0,0,.78))}
.sd-play{position:absolute;right:34rpx;top:220rpx;width:92rpx;height:92rpx;border-radius:50%;background:rgba(255,255,255,.14);display:flex;align-items:center;justify-content:center;border:1rpx solid rgba(255,255,255,.3)}
.sd-copy{position:absolute;left:28rpx;right:28rpx;bottom:32rpx}
.sd-title{font-size:44rpx;font-weight:900;line-height:1.15}
.sd-meta{font-size:24rpx;color:var(--text-sub);margin-top:12rpx}
.sd-data{font-size:22rpx;color:var(--text-weak);margin-top:10rpx}
.media-flow{padding:24rpx}
.media-item{height:420rpx;border-radius:24rpx;overflow:hidden;position:relative;margin-bottom:22rpx;background:var(--bg-card);border:1rpx solid var(--line-soft);box-shadow:var(--shadow)}
.media-img{width:100%;height:100%}
.media-label{position:absolute;left:18rpx;top:18rpx;padding:8rpx 16rpx;border-radius:999rpx;background:rgba(0,0,0,.34);color:var(--text-sub);font-size:22rpx}
.media-play{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:74rpx;height:74rpx;border-radius:50%;background:rgba(255,255,255,.16);display:flex;align-items:center;justify-content:center}
.people-strip{display:flex;gap:12rpx;padding:4rpx 24rpx 24rpx}
.person-dot{width:62rpx;height:62rpx;border-radius:50%;background:linear-gradient(135deg,var(--green-dark),var(--blue-soft));display:flex;align-items:center;justify-content:center;font-weight:900;border:2rpx solid rgba(255,255,255,.25)}
.story-lines{margin:0 24rpx;background:var(--bg-card);border:1rpx solid var(--line-soft);border-radius:22rpx;padding:24rpx;font-size:27rpx;line-height:1.75;color:var(--text-sub)}
.next-story{margin:24rpx;color:var(--green-main);font-size:26rpx;font-weight:900}
.sd-bottom{position:fixed;left:22rpx;right:22rpx;bottom:calc(18rpx + env(safe-area-inset-bottom));background:rgba(7,17,15,.88);border:1rpx solid var(--line-soft);border-radius:999rpx;padding:18rpx 24rpx;color:var(--text-sub);font-size:24rpx;text-align:center;backdrop-filter:blur(20rpx)}
