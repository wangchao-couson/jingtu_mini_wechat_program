.fallback {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: linear-gradient(145deg, #F2F8FA 0%, #FFFFFF 52%, #E7F5F2 100%);
}

.card {
  width: 100%;
  padding: 44rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, .86);
  box-shadow: 0 24rpx 70rpx rgba(92, 74, 50, .14);
}

.title {
  color: #123D42;
  font-size: 36rpx;
  font-weight: 700;
}

.desc {
  margin-top: 18rpx;
  color: #5E7D82;
  font-size: 26rpx;
  line-height: 1.7;
}
