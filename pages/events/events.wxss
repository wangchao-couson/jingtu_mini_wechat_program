.disc-page{padding-bottom:40rpx}
.disc-tabs{display:flex;background:var(--card);padding:14rpx 24rpx;gap:8rpx;position:sticky;top:0;z-index:10;box-shadow:0 1rpx 4rpx rgba(0,0,0,0.03)}
.disc-tab{flex:1;text-align:center;padding:12rpx 0;border-radius:24rpx;font-size:26rpx;font-weight:500;color:var(--text-secondary);background:var(--bg);transition:all .2s}
.disc-tab.active{background:var(--primary);color:#fff;font-weight:600;box-shadow:0 3rpx 12rpx rgba(45,111,247,0.2)}
.disc-list{padding:12rpx 24rpx}

.disc-card{margin-bottom:16rpx;background:var(--card);border-radius:var(--radius-xl);overflow:hidden;box-shadow:var(--shadow);display:block;text-decoration:none;color:inherit}
.disc-cover{width:100%;height:180rpx}
.disc-body{padding:18rpx 22rpx 20rpx}
.disc-badge-row{margin-bottom:8rpx}
.disc-title{font-size:28rpx;font-weight:700;line-height:1.3;margin-bottom:6rpx;color:var(--text)}
.disc-meta{font-size:22rpx;color:var(--text-light);margin-bottom:10rpx;display:flex;flex-wrap:wrap;gap:6rpx 16rpx}
.disc-faces{display:flex;align-items:center;margin-bottom:10rpx}
.disc-face{width:28rpx;height:28rpx;border-radius:50%;background:linear-gradient(135deg,var(--primary),#4F8CFF);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12rpx;font-weight:600;border:2rpx solid var(--card);margin-left:-6rpx}
.disc-face:first-child{margin-left:0}
.disc-face-more{width:28rpx;height:28rpx;border-radius:50%;background:var(--border);color:var(--text-secondary);display:flex;align-items:center;justify-content:center;font-size:12rpx;border:2rpx solid var(--card);margin-left:-6rpx}
.disc-footer{display:flex;align-items:center;justify-content:space-between;padding-top:12rpx;border-top:1rpx solid var(--border-light)}
.disc-leader{font-size:22rpx;color:var(--text-secondary)}
.disc-join{font-size:24rpx;color:var(--primary);font-weight:600}
