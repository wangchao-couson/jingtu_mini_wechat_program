.disc-page{padding-bottom:40rpx}
.disc-tabs{display:flex;background:var(--card);padding:14rpx 24rpx;gap:8rpx;position:sticky;top:0;z-index:10;box-shadow:0 2rpx 8rpx rgba(0,0,0,0.03)}
.disc-tab{flex:1;text-align:center;padding:12rpx 0;border-radius:28rpx;font-size:26rpx;font-weight:500;color:var(--gray);background:var(--page);transition:all .2s}
.disc-tab.active{background:var(--deep);color:#fff;font-weight:600;box-shadow:0 4rpx 16rpx rgba(13,43,53,0.24)}
.disc-list{padding:16rpx 24rpx}
.disc-tag-row{margin-bottom:10rpx}
.disc-footer{display:flex;align-items:center;justify-content:space-between;margin-top:12rpx}
.disc-leader{font-size:22rpx;color:var(--gray)}
.disc-join{font-size:24rpx;color:var(--teal);font-weight:600}
