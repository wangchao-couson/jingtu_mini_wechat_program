.disc-page{padding-bottom:48rpx;background:radial-gradient(circle at 20% 0,rgba(53,208,127,.12),transparent 36%),var(--bg-main);min-height:100vh;color:#fff}
.disc-hero{height:360rpx;position:relative;overflow:hidden;background:#d8d1c2}
.disc-hero-img{width:100%;height:100%}
.disc-hero-shade{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,0.04),rgba(14,25,18,0.78))}
.disc-hero-copy{position:absolute;left:28rpx;right:28rpx;bottom:28rpx;color:#fff}
.disc-hero-eyebrow{display:inline-block;padding:8rpx 18rpx;border-radius:999rpx;background:rgba(255,253,248,0.18);font-size:20rpx;font-weight:800;letter-spacing:2rpx;margin-bottom:14rpx}
.disc-hero-title{font-size:42rpx;font-weight:900;line-height:1.16;margin-bottom:10rpx}
.disc-hero-sub{font-size:24rpx;line-height:1.55;color:rgba(255,255,255,0.82)}
.module-head{display:flex;align-items:flex-end;justify-content:space-between;gap:16rpx;padding:28rpx 24rpx 16rpx}
.module-title{font-size:32rpx;font-weight:900;color:#fff}
.module-sub{font-size:23rpx;color:var(--text-sub);line-height:1.5;margin-top:6rpx}
.module-more{font-size:22rpx;color:var(--green-main);font-weight:800;white-space:nowrap}
.idea-scroll{white-space:nowrap;padding-left:24rpx}
.idea-card{display:inline-block;width:540rpx;height:330rpx;margin-right:18rpx;border-radius:24rpx;overflow:hidden;position:relative;background:#111;border:1rpx solid var(--line-soft);box-shadow:var(--shadow)}
.idea-img{width:100%;height:100%}
.idea-mask{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,.18),rgba(0,0,0,.78))}
.idea-copy{position:absolute;left:22rpx;right:22rpx;bottom:22rpx;color:#fff}
.idea-rec{font-size:21rpx;color:var(--text-sub);font-weight:800}
.idea-title{font-size:34rpx;font-weight:900;margin-top:8rpx}
.idea-reason{font-size:24rpx;color:var(--text-sub);line-height:1.45;margin-top:8rpx;white-space:normal}
.idea-foot{display:flex;gap:14rpx;margin-top:14rpx}
.idea-foot text{padding:7rpx 14rpx;border-radius:999rpx;background:rgba(53,208,127,.16);color:var(--green-main);font-size:21rpx;font-weight:900}
.disc-tabs{display:flex;background:rgba(7,17,15,0.82);padding:16rpx 24rpx;gap:10rpx;position:sticky;top:0;z-index:10;box-shadow:0 8rpx 28rpx rgba(0,0,0,0.28);backdrop-filter:blur(18rpx)}
.disc-tab{flex:1;text-align:center;padding:14rpx 0;border-radius:24rpx;font-size:25rpx;font-weight:600;color:var(--text-secondary);background:rgba(255,255,255,.08);transition:all .2s}
.disc-tab.active{background:var(--primary);color:#fff;box-shadow:0 8rpx 20rpx rgba(31,107,82,0.18)}
.disc-list{padding:18rpx 24rpx}

.disc-card{margin-bottom:22rpx;background:var(--bg-card);border-radius:22rpx;overflow:hidden;box-shadow:var(--shadow-md);display:block;text-decoration:none;color:inherit;border:1rpx solid var(--line-soft)}
.disc-media{height:250rpx;position:relative;overflow:hidden;background:#D8D1C2}
.disc-cover{width:100%;height:100%}
.disc-media-shade{position:absolute;left:0;right:0;bottom:0;height:58%;background:linear-gradient(180deg,rgba(0,0,0,0),rgba(18,25,20,0.58))}
.disc-template{position:absolute;left:22rpx;bottom:20rpx;color:#fff;font-size:24rpx;font-weight:700;letter-spacing:1rpx}
.disc-capacity{position:absolute;right:18rpx;top:18rpx;padding:6rpx 14rpx;border-radius:999rpx;background:rgba(255,253,248,0.92);color:var(--primary);font-size:22rpx;font-weight:700}
.disc-body{padding:20rpx 24rpx 22rpx}
.disc-badge-row{margin-bottom:10rpx}
.disc-title{font-size:31rpx;font-weight:800;line-height:1.3;margin-bottom:8rpx;color:var(--text)}
.disc-meta{font-size:23rpx;color:var(--text-secondary);margin-bottom:14rpx;display:flex;flex-wrap:wrap;gap:8rpx 18rpx}
.disc-meta text{position:relative;padding-left:16rpx}
.disc-meta text::before{content:'';position:absolute;left:0;top:14rpx;width:6rpx;height:6rpx;border-radius:50%;background:var(--accent)}
.disc-faces{display:flex;align-items:center;margin-bottom:10rpx}
.disc-face{width:32rpx;height:32rpx;border-radius:50%;background:linear-gradient(135deg,var(--primary),var(--sky));color:#fff;display:flex;align-items:center;justify-content:center;font-size:13rpx;font-weight:700;border:2rpx solid var(--card);margin-left:-6rpx}
.disc-face:first-child{margin-left:0}
.disc-face-more{width:32rpx;height:32rpx;border-radius:50%;background:var(--border);color:var(--text-secondary);display:flex;align-items:center;justify-content:center;font-size:12rpx;border:2rpx solid var(--card);margin-left:-6rpx}
.disc-footer{display:flex;align-items:center;justify-content:space-between;padding-top:12rpx;border-top:1rpx solid var(--border-light)}
.disc-leader{font-size:22rpx;color:var(--text-secondary)}
.disc-join{font-size:24rpx;color:var(--primary);font-weight:800}
.tone-night .disc-capacity{color:#365A75}
.tone-lake .disc-capacity{color:#2F7380}
.tone-ember .disc-capacity{color:#B96236}
