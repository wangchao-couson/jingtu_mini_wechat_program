<view class="disc-page">
  <view class="disc-tabs">
    <view class="disc-tab {{tab==='open'?'active':''}}" bindtap="switchTab" data-tab="open">招募中</view>
    <view class="disc-tab {{tab==='soon'?'active':''}}" bindtap="switchTab" data-tab="soon">即将开始</view>
    <view class="disc-tab {{tab==='done'?'active':''}}" bindtap="switchTab" data-tab="done">已结束</view>
  </view>

  <view class="disc-list" wx:if="{{list.length>0}}">
    <navigator wx:for="{{list}}" wx:key="id" url="/pages/story/story?id={{item.id}}" class="disc-card">
      <image src="{{item.cover}}" mode="aspectFill" class="disc-cover"/>
      <view class="disc-body">
        <view class="disc-badge-row"><text class="status-tag {{item.status==='registering'?'status-open':item.status==='upcoming'?'status-soon':'status-done'}}">{{item.status==='registering'?'招募中':item.status==='upcoming'?'即将开始':'已结束'}}</text></view>
        <view class="disc-title">{{item.title}}</view>
        <view class="disc-meta"><text>📅 {{item.date}}</text><text>📍 {{item.location}}</text><text>📏 {{item.distance}}</text></view>
        <view class="disc-faces">
          <view class="disc-face" wx:for="{{item.faceList}}" wx:key="*this" wx:for-item="f">{{f}}</view>
          <view class="disc-face-more" wx:if="{{item.currentParticipants>item.faceList.length}}">+{{item.currentParticipants-item.faceList.length}}</view>
        </view>
        <view class="disc-footer">
          <text class="disc-leader">🎯 领队：{{item.leader.name}}</text>
          <text class="disc-join" wx:if="{{item.status==='registering'}}">联系加入 →</text>
        </view>
      </view>
    </navigator>
  </view>
  <view class="empty-state" wx:else><view class="empty-icon">🧭</view><view class="empty-text">暂无活动</view></view>
</view>