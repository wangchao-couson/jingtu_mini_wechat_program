<view class="disc-page">
  <view class="mini-status">
    <text>发现</text>
    <view class="capsule">···</view>
  </view>

  <view class="disc-hero">
    <image src="{{hero.cover}}" mode="aspectFill" class="disc-hero-img"/>
    <view class="disc-hero-shade"></view>
    <view class="disc-hero-copy">
      <view class="disc-hero-eyebrow">{{hero.eyebrow}}</view>
      <view class="disc-hero-title">{{hero.title}}</view>
      <view class="disc-hero-sub">{{hero.subtitle}}</view>
    </view>
  </view>

  <view class="module-head">
    <view>
      <view class="module-title">路线灵感池</view>
      <view class="module-sub">你想去的地方，也可能成为京途下一场活动。</view>
    </view>
    <view class="module-more" bindtap="showRecommend">我想推荐 ></view>
  </view>

  <scroll-view scroll-x class="idea-scroll" show-scrollbar="{{false}}">
    <navigator class="idea-card" wx:for="{{routeIdeas}}" wx:key="id" url="/pages/route-detail/route-detail?id={{item.id}}">
      <image src="{{item.cover}}" mode="aspectFill" class="idea-img"/>
      <view class="idea-mask"></view>
      <view class="idea-copy">
        <view class="idea-rec">{{item.recommender}}</view>
        <view class="idea-title">{{item.title}}</view>
        <view class="idea-reason">{{item.reason}}</view>
        <view class="idea-foot"><text>{{item.count}}人想去</text><text>{{item.status}}</text></view>
      </view>
    </navigator>
  </scroll-view>

  <view class="module-head" id="activity-section">
    <view class="module-title">下一段出发</view>
    <view class="module-more" bindtap="showAllActivities">全部活动 ></view>
  </view>

  <view class="disc-tabs">
    <view class="disc-tab {{tab==='open'?'active':''}}" bindtap="switchTab" data-tab="open">正在出发</view>
    <view class="disc-tab {{tab==='soon'?'active':''}}" bindtap="switchTab" data-tab="soon">活动预告</view>
    <view class="disc-tab {{tab==='done'?'active':''}}" bindtap="switchTab" data-tab="done">故事回顾</view>
  </view>

  <view class="disc-list" wx:if="{{list.length>0}}">
    <navigator wx:for="{{list}}" wx:key="id" url="/pages/team-detail/team-detail?id={{item.id}}" class="disc-card tone-{{item.template.tone}}">
      <view class="disc-media">
        <image src="{{item.cover}}" mode="aspectFill" class="disc-cover"/>
        <view class="disc-media-shade"></view>
        <view class="disc-template">{{item.template.label}}</view>
        <view class="disc-capacity">{{item.peopleText}} 人</view>
      </view>
      <view class="disc-body">
        <view class="disc-badge-row"><text class="status-tag {{item.status==='registering'?'status-open':item.status==='upcoming'?'status-soon':'status-done'}}">{{item.status==='registering'?'正在出发':item.status==='upcoming'?'活动预告':'故事回顾'}}</text></view>
        <view class="disc-title">{{item.title}}</view>
        <view class="disc-meta"><text>{{item.date}}</text><text>{{item.location}}</text><text>{{item.distance}}</text></view>
        <view class="disc-faces">
          <view class="disc-face" wx:for="{{item.faceList}}" wx:key="*this" wx:for-item="f">{{f}}</view>
          <view class="disc-face-more" wx:if="{{item.extraPeopleText>0}}">+{{item.extraPeopleText}}</view>
        </view>
        <view class="disc-footer">
          <text class="disc-leader">{{item.leader.roleName}} · {{item.leader.name}}</text>
          <text class="disc-join">咨询详情</text>
        </view>
      </view>
    </navigator>
  </view>
  <view class="empty-state" wx:else><view class="empty-icon">🧭</view><view class="empty-text">暂无活动</view></view>
</view>
