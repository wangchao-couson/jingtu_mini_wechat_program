<view class="disc-page">
  <view class="disc-tabs">
    <view class="disc-tab {{tab==='open'?'active':''}}" bindtap="switchTab" data-tab="open">招募中</view>
    <view class="disc-tab {{tab==='soon'?'active':''}}" bindtap="switchTab" data-tab="soon">即将开始</view>
    <view class="disc-tab {{tab==='done'?'active':''}}" bindtap="switchTab" data-tab="done">已结束</view>
  </view>

  <view wx:if="{{list.length>0}}" class="disc-list">
    <navigator wx:for="{{list}}" wx:key="id" url="/pages/event-detail/event-detail?id={{item.id}}" class="story-card">
      <image src="{{item.cover}}" mode="aspectFill" class="story-cover" style="height:180rpx"/>
      <view class="story-body">
        <view class="disc-tag-row"><text class="status-tag {{item.status==='registering'?'status-open':item.status==='upcoming'?'status-soon':'status-done'}}">{{item.status==='registering'?'招募中':item.status==='upcoming'?'即将开始':'已结束'}}</text></view>
        <view class="story-title" style="font-size:28rpx">{{item.title}}</view>
        <view class="story-meta">{{item.date}} · {{item.location}} · {{item.distance}}</view>
        <view class="story-faces">
          <view class="story-face" wx:for="{{item.faceList}}" wx:key="*this" wx:for-item="f">{{f}}</view>
          <view class="story-face-more" wx:if="{{item.currentParticipants>item.faceList.length}}">+{{item.currentParticipants-item.faceList.length}}</view>
        </view>
        <view class="disc-footer">
          <text class="disc-leader">🎯 领队：{{item.leader.name}}</text>
          <text class="disc-join" wx:if="{{item.status==='registering'}}">联系加入 →</text>
        </view>
      </view>
    </navigator>
  </view>
  <view class="empty-state" wx:else><view class="empty-icon">🧭</view><view class="empty-text">暂无活动</view></view>
</view>