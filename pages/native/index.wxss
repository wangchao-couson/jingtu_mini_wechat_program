page {
  min-height: 100vh;
  color: #3F3324;
  background: #F5F0E8;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 54rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(139, 111, 71, .18), transparent 34%),
    radial-gradient(circle at 88% 12%, rgba(217, 194, 163, .42), transparent 30%),
    linear-gradient(145deg, #F5F0E8 0%, #F8F5EF 54%, #EFE3D2 100%);
}

.header {
  position: sticky;
  top: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 6rpx 20rpx;
  backdrop-filter: blur(18px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.mark {
  width: 78rpx;
  height: 78rpx;
  border-radius: 30rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 46rpx rgba(92, 74, 50, .18);
}

.brand-title {
  font-size: 36rpx;
  line-height: 1.1;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.brand-sub {
  margin-top: 4rpx;
  color: #8B7B64;
  font-size: 22rpx;
}

.mini-btn {
  padding: 18rpx 24rpx;
  color: #5C4A32;
  border-radius: 999rpx;
  background: #D9C2A3;
  font-size: 24rpx;
  font-weight: 900;
}

.hero {
  height: 366rpx;
  overflow: hidden;
  border-radius: 56rpx;
  box-shadow: 0 30rpx 80rpx rgba(92, 74, 50, .18);
}

.slide,
.cover,
.detail-hero {
  position: relative;
  overflow: hidden;
  color: #fff;
}

.slide {
  height: 100%;
  padding: 38rpx;
}

.type-green { background: linear-gradient(135deg, #5C4A32, #8B6F47, #D9C2A3); }
.type-gold { background: linear-gradient(135deg, #4F3E2A, #8B6F47, #C9A77D); }
.type-blue { background: linear-gradient(135deg, #5C4A32, #9A7A52, #D9C2A3); }
.type-teal { background: linear-gradient(135deg, #4A3A28, #8B6F47, #E7D7C1); }
.type-orange { background: linear-gradient(135deg, #5C4A32, #A98257, #D9C2A3); }

.photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.photo-shade {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(90deg, rgba(45, 35, 24, .78) 0%, rgba(66, 49, 31, .36) 56%, rgba(66, 49, 31, .08) 100%),
    linear-gradient(0deg, rgba(45, 35, 24, .5) 0%, rgba(45, 35, 24, .08) 48%);
}

.detail-shade {
  background:
    linear-gradient(0deg, rgba(45, 35, 24, .78) 0%, rgba(45, 35, 24, .1) 58%),
    linear-gradient(90deg, rgba(45, 35, 24, .48) 0%, rgba(45, 35, 24, .08) 100%);
}

.route-lines {
  position: absolute;
  left: 38rpx;
  top: 52rpx;
  z-index: 1;
  display: grid;
  gap: 14rpx;
}

.route-lines view {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.55);
}

.route-lines view:nth-child(1) { width: 92rpx; }
.route-lines view:nth-child(2) { width: 150rpx; }
.route-lines view:nth-child(3) { width: 70rpx; }
.route-lines.small {
  top: 32rpx;
  left: 28rpx;
  transform: scale(.76);
  transform-origin: left top;
}

.orb {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,.15);
}

.orb-a {
  right: 48rpx;
  top: 34rpx;
  width: 150rpx;
  height: 150rpx;
}

.orb-b {
  left: 42rpx;
  bottom: 22rpx;
  width: 118rpx;
  height: 118rpx;
}

.mountain-a,
.mountain-b {
  position: absolute;
  left: -40rpx;
  right: -40rpx;
  bottom: -64rpx;
  height: 190rpx;
  border-radius: 50% 50% 0 0;
  background: rgba(23,53,31,.24);
  transform: rotate(-4deg);
}

.mountain-b {
  bottom: -92rpx;
  background: rgba(255,253,246,.23);
  transform: rotate(7deg);
}

.hero-symbol,
.cover-symbol,
.detail-symbol {
  position: absolute;
  right: 44rpx;
  bottom: 54rpx;
  z-index: 1;
  color: rgba(255,255,255,.32);
  font-size: 130rpx;
  font-weight: 900;
}

.slide-copy {
  position: relative;
  z-index: 3;
  width: 72%;
  padding-top: 48rpx;
}

.eyebrow {
  margin-bottom: 14rpx;
  opacity: .9;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.slide-title {
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 900;
}

.slide-sub {
  margin-top: 18rpx;
  opacity: .92;
  font-size: 26rpx;
  line-height: 1.55;
}

.search-row {
  display: flex;
  gap: 18rpx;
  margin: 28rpx 0 20rpx;
}

.search-row input {
  flex: 1;
  height: 92rpx;
  padding: 0 26rpx;
  border-radius: 34rpx;
  color: #3F3324;
  background: rgba(255,255,255,.82);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.8);
}

.search-row button {
  width: 92rpx;
  height: 92rpx;
  color: #fff;
  border-radius: 32rpx;
  background: #5C4A32;
  box-shadow: 0 20rpx 42rpx rgba(92,74,50,.22);
}

.chips {
  width: 100%;
  white-space: nowrap;
  padding-bottom: 22rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  padding: 18rpx 26rpx;
  color: #5C4A32;
  border-radius: 999rpx;
  background: rgba(255,255,255,.76);
  font-size: 26rpx;
}

.chip.active {
  color: #fff;
  background: #5C4A32;
  box-shadow: 0 14rpx 38rpx rgba(92,74,50,.2);
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 20rpx 4rpx 18rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
}

.section-count {
  color: #8B7B64;
  font-size: 24rpx;
}

.list {
  display: grid;
  gap: 24rpx;
}

.activity-card {
  overflow: hidden;
  border-radius: 44rpx;
  background: rgba(255,255,255,.9);
  box-shadow: 0 24rpx 62rpx rgba(92,74,50,.12);
}

.cover {
  height: 250rpx;
}

.cover-symbol {
  font-size: 100rpx;
  right: 44rpx;
  bottom: 46rpx;
}

.badge,
.hot {
  position: absolute;
  z-index: 4;
  top: 22rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 900;
}

.badge {
  left: 22rpx;
  color: #fff;
  background: rgba(0,0,0,.22);
}

.hot {
  right: 22rpx;
  color: #5C4A32;
  background: rgba(247,231,171,.92);
}

.hot.expired {
  color: #8B7B64;
  background: rgba(245,240,232,.9);
}

.activity-card.is-expired {
  filter: grayscale(.18);
  opacity: .72;
}

.badge.inline {
  position: static;
  display: inline-flex;
  width: auto;
}

.card-body {
  padding: 24rpx;
}

.card-title {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.price {
  flex-shrink: 0;
  color: #8B6F47;
}

.meta {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  color: #8B7B64;
  font-size: 23rpx;
}

.meta text {
  color: #3F3324;
  font-weight: 900;
}

.empty {
  padding: 54rpx 30rpx;
  color: #8B7B64;
  text-align: center;
  border: 2rpx dashed rgba(92,74,50,.18);
  border-radius: 40rpx;
  background: rgba(255,255,255,.55);
}

.detail {
  padding-bottom: 30rpx;
}

.detail-hero {
  height: 500rpx;
  margin: -24rpx -24rpx 0;
  border-radius: 0 0 60rpx 60rpx;
  box-shadow: 0 30rpx 80rpx rgba(92,74,50,.18);
}

.back {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  z-index: 6;
  width: 82rpx;
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  color: #fff;
  border-radius: 50%;
  background: rgba(92, 74, 50, .42);
  box-shadow: 0 16rpx 42rpx rgba(0,0,0,.18);
  backdrop-filter: blur(16px);
}

.back-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #5C4A32;
  background: #FFFFFF;
  font-size: 48rpx;
  line-height: 1;
  font-weight: 900;
}

.detail-symbol {
  right: 54rpx;
  bottom: 120rpx;
  font-size: 170rpx;
}

.detail-title {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 44rpx;
  z-index: 5;
}

.detail-name {
  margin-top: 14rpx;
  color: #fff;
  font-size: 56rpx;
  line-height: 1.1;
  font-weight: 900;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin: 26rpx 0;
}

.info-tile {
  min-height: 132rpx;
  padding: 22rpx 18rpx;
  border-radius: 32rpx;
  background: rgba(255,255,255,.86);
}

.info-tile text {
  display: block;
  margin-bottom: 8rpx;
  color: #8B7B64;
  font-size: 22rpx;
}

.info-tile view {
  color: #3F3324;
  font-size: 24rpx;
  font-weight: 900;
}

.panel {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,.86);
}

.panel-title {
  margin-bottom: 16rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.paragraph,
.bullet {
  color: #5C4A32;
  font-size: 27rpx;
  line-height: 1.75;
}

.contact-card {
  display: block;
  margin-top: 26rpx;
  padding: 26rpx;
  color: #fff;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #5C4A32, #8B6F47);
  box-shadow: 0 30rpx 76rpx rgba(92,74,50,.22);
}

.contact-card.disabled {
  color: #8B7B64;
  background: linear-gradient(135deg, #D8D1C6, #EFE7DC);
  box-shadow: none;
}

.contact-title {
  margin-bottom: 10rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.contact-desc {
  margin-bottom: 18rpx;
  opacity: .88;
  font-size: 24rpx;
  line-height: 1.55;
}

.wechat-id {
  display: inline-flex;
  flex: 1;
  min-width: 0;
  padding: 14rpx 18rpx;
  color: #5C4A32;
  border-radius: 999rpx;
  background: #D9C2A3;
  font-size: 24rpx;
  font-weight: 900;
}

.contact-card.disabled .wechat-id {
  color: #8B7B64;
  background: rgba(255,255,255,.62);
}

.wechat-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.copy-btn {
  width: 78rpx;
  height: 78rpx;
  flex: 0 0 78rpx;
  margin-top: 0;
  color: #5C4A32;
  border-radius: 50%;
  background: #FFFFFF;
  font-size: 22rpx;
  font-weight: 900;
}

.copy-btn.disabled {
  color: #A79B8A;
  background: #E7E0D6;
}
