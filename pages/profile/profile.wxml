<view class="mp-page">
  <view class="mp-nav" style="padding-top:{{statusBarHeight}}px">
    <view class="mp-nav-title">我的京途</view>
    <view class="mp-nav-sub">我的足迹、活动、同行者和贡献。</view>
  </view>

  <view class="mp-hero">
    <view class="avatar avatar-xl" style="margin:0 auto 14rpx">{{user.nickname?user.nickname[0]:'途'}}</view>
    <view class="mp-name">{{user.nickname||'京途同学'}}</view>
    <view class="mp-bio">{{user.bio||'热爱自然，在路上遇见更好的自己'}}</view>
    <view class="flex gap-6 flex-wrap" style="justify-content:center;margin:10rpx 0">
      <text class="tag tag-teal" wx:for="{{user.tags||[]}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">足迹地图</view>
    <view class="mp-footprint dark-map">
      <text class="mp-fp-icon">•</text>
      <text class="mp-fp-text">北京 · 河北 · 内蒙古 · 青海 · 河南</text>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">我的数据</view>
    <view class="mp-stats year-stats">
      <view class="mp-stat" wx:for="{{yearStats}}" wx:key="label"><text class="mp-stat-num">{{item.num}}</text><text class="mp-stat-label">{{item.label}}</text></view>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">我的同行者</view>
    <view class="mp-comp" wx:for="{{topCompanions}}" wx:key="id">
      <view class="avatar">{{item.name[0]}}</view>
      <view class="flex-1"><view class="fs-28 font-bold">{{item.name}}</view><view class="fs-22 text-gray">{{item.bio}}</view></view>
      <text class="mp-comp-count">{{item.count}}次</text>
    </view>
    <view class="empty-text fs-22" wx:if="{{topCompanions.length===0}}" style="padding:16rpx 0">还没有同行者记录</view>
  </view>

  <view class="detail-section">
    <view class="detail-title">我的故事</view>
    <view class="mp-memory">
      <view class="mp-memory-label">✦ 时光机</view>
      <view class="mp-memory-word">"{{memoryText}}"</view>
      <view class="mp-memory-meta">{{memoryMeta}}</view>
    </view>
    <view class="mp-story-chip" wx:for="{{myStories}}" wx:key="*this">{{item}}</view>
  </view>

  <view class="detail-section">
    <view class="detail-title">我关注的出发 ({{participations.length}})</view>
    <block wx:if="{{participations.length===0}}">
      <view class="empty-text fs-22" style="padding:12rpx 0">还没有关注的出发</view>
    </block>
    <block wx:else>
      <view class="mp-join" wx:for="{{participations}}" wx:key="id">
      <image src="{{item.eventCover}}" mode="aspectFill" class="mp-join-img"/>
      <view class="flex-1"><view class="fs-26 font-bold">{{item.eventTitle}}</view><view class="fs-22 text-light">{{item.eventDate}}</view></view>
      <text class="status-tag status-open">已关注</text>
      </view>
    </block>
  </view>

  <view class="detail-section">
    <view class="detail-title">更多</view>
    <view class="mp-setting" bindtap="editProfile">编辑资料</view>
    <view class="mp-setting" bindtap="showAbout">关于京途</view>
  </view>
  <view style="height:40rpx"></view>
</view>
