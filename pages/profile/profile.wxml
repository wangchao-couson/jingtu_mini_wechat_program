<view class="mp-page">
  <view class="mp-nav" style="padding-top:{{statusBarHeight}}px">
    <view class="mp-nav-title">我的京途档案</view>
    <view class="mp-nav-sub">2026.3 加入</view>
  </view>

  <view class="mp-hero">
    <view class="avatar avatar-xl" style="margin:0 auto 14rpx">{{user.nickname?user.nickname[0]:'途'}}</view>
    <view class="mp-name">{{user.nickname||'京途同学'}}</view>
    <view class="mp-bio">{{user.bio||'热爱自然，在路上遇见更好的自己'}}</view>
    <view class="flex gap-6 flex-wrap" style="justify-content:center;margin:10rpx 0">
      <text class="tag tag-teal" wx:for="{{user.tags||[]}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">我的户外足迹</view>
    <view class="mp-stats">
      <view class="mp-stat"><text class="mp-stat-num">{{user.totalEvents||0}}</text><text class="mp-stat-label">参加次数</text></view>
      <view class="mp-stat"><text class="mp-stat-num teal">{{user.totalKm||0}}</text><text class="mp-stat-label">累计公里</text></view>
      <view class="mp-stat"><text class="mp-stat-num mint">{{user.totalDays||0}}</text><text class="mp-stat-label">累计天数</text></view>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">🤝 最常同行</view>
    <view class="mp-comp" wx:for="{{topCompanions}}" wx:key="id">
      <view class="avatar">{{item.name[0]}}</view>
      <view class="flex-1"><view class="fs-28 font-bold">{{item.name}}</view><view class="fs-22 text-gray">{{item.bio}}</view></view>
      <text class="mp-comp-count">{{item.count}}次</text>
    </view>
    <view class="empty-text fs-22" wx:if="{{topCompanions.length===0}}" style="padding:16rpx 0">还没有一起出行的同学</view>
  </view>

  <view class="detail-section">
    <view class="detail-title">✨ 京途回忆</view>
    <view class="mp-memory">
      <view class="mp-memory-label">✦ 时光机</view>
      <view class="mp-memory-word">"{{memoryText}}"</view>
      <view class="mp-memory-meta">{{memoryMeta}}</view>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">🗺️ 足迹地图</view>
    <view class="mp-footprint">
      <text class="mp-fp-icon">📍</text>
      <text class="mp-fp-text">已点亮 {{visitedPlaces.length}} 个地方</text>
    </view>
    <view class="flex gap-6 flex-wrap" style="margin-top:12rpx">
      <text class="mp-fp-tag" wx:for="{{visitedPlaces}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="detail-section">
    <view class="detail-title">📋 我的加入 ({{participations.length}})</view>
    <block wx:if="{{participations.length===0}}">
      <view class="empty-text fs-22" style="padding:12rpx 0">还没有加入活动</view>
    </block>
    <block wx:else>
      <view class="mp-join" wx:for="{{participations}}" wx:key="id">
      <image src="{{item.eventCover}}" mode="aspectFill" class="mp-join-img"/>
      <view class="flex-1"><view class="fs-26 font-bold">{{item.eventTitle}}</view><view class="fs-22 text-light">{{item.eventDate}}</view></view>
      <text class="status-tag status-open">已加入</text>
      </view>
    </block>
  </view>

  <view class="detail-section">
    <view class="detail-title">⚙️</view>
    <view class="mp-setting" bindtap="editProfile">✏️ 编辑资料</view>
    <view class="mp-setting" bindtap="showAbout">ℹ️ 关于京途</view>
  </view>
  <view style="height:40rpx"></view>
</view>