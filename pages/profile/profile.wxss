.mp-page{background:var(--page);padding-bottom:40rpx}
.mp-nav{background:linear-gradient(160deg,var(--deep),#0a1f28);padding-bottom:56rpx;text-align:center}
.mp-nav-title{font-size:32rpx;font-weight:600;color:#fff}
.mp-nav-sub{font-size:22rpx;color:rgba(255,255,255,0.5);margin-top:4rpx}
.mp-hero{margin:-40rpx 24rpx 16rpx;background:var(--card);border-radius:var(--radius-xl);padding:28rpx 32rpx 24rpx;text-align:center;box-shadow:var(--shadow-md)}
.mp-name{font-size:34rpx;font-weight:700;margin-bottom:4rpx}
.mp-bio{font-size:24rpx;color:var(--gray);margin-bottom:4rpx}
.detail-section{margin:16rpx 24rpx;background:var(--card);border-radius:var(--radius-lg);padding:24rpx;box-shadow:var(--shadow)}
.detail-title{font-size:28rpx;font-weight:700;margin-bottom:14rpx;color:var(--ink)}
.mp-stats{display:flex;gap:10rpx}
.mp-stat{flex:1;text-align:center;padding:18rpx 8rpx;background:var(--page);border-radius:var(--radius)}
.mp-stat-num{display:block;font-size:38rpx;font-weight:700}
.mp-stat-num.teal{color:var(--teal)}
.mp-stat-num.mint{color:var(--mint)}
.mp-stat-label{font-size:20rpx;color:var(--light);margin-top:4rpx}
.mp-comp{display:flex;align-items:center;gap:14rpx;padding:14rpx 0}
.mp-comp+.mp-comp{border-top:1rpx solid var(--line)}
.mp-comp-count{font-size:32rpx;font-weight:700;color:var(--amber)}
.mp-memory{background:linear-gradient(135deg,var(--deep),#0a1f28);border-radius:var(--radius-lg);padding:28rpx 24rpx;position:relative;overflow:hidden;color:#fff}
.mp-memory::after{content:'';position:absolute;top:-40rpx;right:-40rpx;width:140rpx;height:140rpx;border-radius:50%;background:rgba(255,255,255,0.03)}
.mp-memory-label{font-size:20rpx;letter-spacing:3rpx;opacity:0.5;margin-bottom:10rpx;position:relative;z-index:1}
.mp-memory-word{font-size:26rpx;font-weight:600;line-height:1.6;position:relative;z-index:1}
.mp-memory-meta{font-size:22rpx;opacity:0.55;margin-top:10rpx;position:relative;z-index:1}
.mp-footprint{text-align:center;padding:28rpx;background:var(--page);border-radius:var(--radius)}
.mp-fp-icon{font-size:44rpx;display:block;margin-bottom:8rpx}
.mp-fp-text{font-size:24rpx;color:var(--gray)}
.mp-fp-tag{padding:6rpx 16rpx;background:rgba(26,92,115,0.06);border-radius:16rpx;font-size:22rpx;color:var(--blue)}
.mp-join{display:flex;align-items:center;gap:14rpx;padding:14rpx 0}
.mp-join+.mp-join{border-top:1rpx solid var(--line)}
.mp-join-img{width:90rpx;height:72rpx;border-radius:var(--radius);flex-shrink:0}
.mp-setting{padding:16rpx 0;font-size:26rpx;color:var(--text)}
.mp-setting+.mp-setting{border-top:1rpx solid var(--line)}
