.rd-page{min-height:100vh;background:radial-gradient(circle at 20% 0,rgba(53,208,127,.12),transparent 36%),var(--bg-main);color:#fff;padding-bottom:42rpx}
.rd-hero{height:520rpx;position:relative;overflow:hidden;background:#111}
.rd-cover{width:100%;height:100%}
.rd-shade{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(7,17,15,.86))}
.rd-copy{position:absolute;left:30rpx;right:30rpx;bottom:32rpx}
.rd-eyebrow{display:inline-block;padding:8rpx 16rpx;border-radius:999rpx;background:rgba(255,255,255,.16);font-size:21rpx;font-weight:900;color:var(--text-sub)}
.rd-title{font-size:54rpx;font-weight:900;line-height:1.12;margin-top:16rpx}
.rd-sub{font-size:24rpx;color:var(--green-main);font-weight:800;margin-top:10rpx}
.rd-section{margin:18rpx 24rpx;background:var(--bg-card);border:1rpx solid var(--line-soft);border-radius:22rpx;padding:24rpx;box-shadow:var(--shadow)}
.rd-section-title{font-size:29rpx;font-weight:900;margin-bottom:12rpx}
.rd-text{font-size:26rpx;line-height:1.75;color:var(--text-sub)}
.rd-grid{display:grid;grid-template-columns:1fr 1fr;gap:12rpx;margin-bottom:16rpx}
.rd-cell{padding:18rpx;border-radius:14rpx;background:rgba(255,255,255,.08);border:1rpx solid var(--line-soft)}
.rd-cell-v{font-size:28rpx;font-weight:900}
.rd-cell-l{font-size:21rpx;color:var(--text-weak);margin-top:4rpx}
.rd-vibe{font-size:25rpx;line-height:1.65;color:var(--text-sub)}
.rd-step{display:flex;align-items:flex-start;gap:14rpx;padding:12rpx 0}
.rd-dot{width:12rpx;height:12rpx;border-radius:50%;background:var(--green-main);margin-top:15rpx;box-shadow:0 0 20rpx rgba(53,208,127,.42)}
.rd-step-text{flex:1;font-size:25rpx;line-height:1.65;color:var(--text-sub)}
.rd-actions{padding:8rpx 24rpx 28rpx}
.rd-btn{height:82rpx;border-radius:999rpx;background:var(--green-main);color:#fff;font-size:28rpx;font-weight:900;border:none;display:flex;align-items:center;justify-content:center}
