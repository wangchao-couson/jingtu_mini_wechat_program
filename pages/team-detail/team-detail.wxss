.td-page{background:radial-gradient(circle at 20% 0,rgba(53,208,127,.12),transparent 36%),var(--bg-main);min-height:100vh;padding-bottom:130rpx;color:#fff}
.td-hero{height:470rpx;position:relative;background:#d8d1c2;overflow:hidden}
.td-hero-img{width:100%;height:100%}
.td-hero-shade{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,0.02),rgba(12,23,17,0.82))}
.td-hero-copy{position:absolute;left:28rpx;right:28rpx;bottom:32rpx;color:#fff}
.td-kicker{display:inline-block;padding:8rpx 18rpx;border-radius:999rpx;background:rgba(255,253,248,0.18);font-size:22rpx;font-weight:800;letter-spacing:2rpx;margin-bottom:14rpx}
.td-title{font-size:44rpx;font-weight:900;line-height:1.15}
.td-meta{font-size:24rpx;color:rgba(255,255,255,0.78);margin-top:12rpx}
.td-section{margin:18rpx 24rpx;background:var(--bg-card);border-radius:22rpx;padding:24rpx;box-shadow:var(--shadow);border:1rpx solid var(--line-soft)}
.td-glance{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx;margin-top:-40rpx;position:relative;z-index:2}
.td-glance-item{background:rgba(255,255,255,.08);border:1rpx solid var(--line-soft);border-radius:18rpx;padding:18rpx 8rpx;text-align:center}
.td-glance-item text:first-child{display:block;color:var(--primary);font-size:30rpx;font-weight:900}
.td-glance-item text:last-child{display:block;color:var(--text-light);font-size:20rpx;margin-top:4rpx}
.td-section-title{font-size:29rpx;font-weight:900;color:var(--text);padding-left:18rpx;position:relative;margin-bottom:16rpx}
.td-section-title::before{content:'';position:absolute;left:0;top:9rpx;width:7rpx;height:24rpx;border-radius:8rpx;background:var(--accent)}
.td-text{font-size:26rpx;line-height:1.85;color:var(--text-secondary)}
.td-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-top:18rpx}
.td-leader{display:flex;align-items:center;gap:16rpx}
.td-leader-img{width:92rpx;height:92rpx;border-radius:24rpx;flex-shrink:0}
.td-leader-info{flex:1}
.td-leader-name{font-size:32rpx;font-weight:900}
.td-leader-role{font-size:23rpx;color:var(--accent);font-weight:700;margin-top:3rpx}
.td-leader-more{font-size:24rpx;color:var(--primary);font-weight:800}
.td-consult{margin-top:18rpx;background:rgba(53,208,127,0.08);border:1rpx solid rgba(53,208,127,0.18);border-radius:18rpx;padding:18rpx;display:flex;align-items:center;gap:16rpx}
.td-consult>view{flex:1}
.td-consult-title{font-size:26rpx;font-weight:900;color:var(--primary)}
.td-consult-note{font-size:22rpx;line-height:1.6;color:var(--text-light);margin-top:4rpx}
.td-consult-btn,.td-bottom-btn{border:0;background:var(--primary);color:#fff;border-radius:999rpx;font-size:24rpx;font-weight:900;padding:0 22rpx;height:64rpx;line-height:64rpx}
.td-time{display:grid;grid-template-columns:110rpx 1fr;gap:16rpx;padding:14rpx 0;border-bottom:1rpx solid var(--border-light)}
.td-time:last-child{border-bottom:0}
.td-time-label{font-size:24rpx;font-weight:900;color:var(--primary)}
.td-time-text{font-size:25rpx;color:var(--text-secondary);line-height:1.65}
.td-include-wrap{display:flex;flex-wrap:wrap;gap:10rpx}
.td-include{display:inline-block;padding:10rpx 18rpx;border-radius:999rpx;background:rgba(31,107,82,0.08);color:var(--primary);font-size:24rpx;font-weight:800}
.td-gallery{display:grid;grid-template-columns:1.15fr .85fr;gap:10rpx}
.td-gallery-img{height:170rpx;border-radius:18rpx}
.td-gallery-img:first-child{height:350rpx;grid-row:span 2}
.td-safe{font-size:24rpx;color:var(--text-secondary);line-height:1.7;padding:10rpx 0}
.td-bottom-space{height:30rpx}
.td-bottom{position:fixed;left:18rpx;right:18rpx;bottom:calc(16rpx + env(safe-area-inset-bottom));z-index:20;background:rgba(7,17,15,0.9);border:1rpx solid var(--border);border-radius:28rpx;padding:14rpx 16rpx;display:flex;align-items:center;gap:16rpx;box-shadow:var(--shadow-lg);backdrop-filter:blur(18rpx)}
.td-bottom-text{flex:1;font-size:25rpx;font-weight:900;color:var(--text)}
