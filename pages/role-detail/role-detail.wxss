.rd-page{background:var(--bg);min-height:100vh;padding-bottom:40rpx}
.rd-hero{height:430rpx;position:relative;background:#d8d1c2;overflow:hidden}
.rd-hero-img{width:100%;height:100%}
.rd-hero-shade{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,0.06),rgba(12,23,17,0.82))}
.rd-hero-copy{position:absolute;left:28rpx;right:28rpx;bottom:30rpx;color:#fff;display:flex;align-items:center;gap:20rpx}
.rd-avatar{width:116rpx;height:116rpx;border-radius:30rpx;border:4rpx solid rgba(255,255,255,0.58);box-shadow:0 14rpx 34rpx rgba(0,0,0,0.22)}
.rd-name{font-size:44rpx;font-weight:900;line-height:1.12}
.rd-role{font-size:24rpx;color:rgba(255,255,255,0.8);margin-top:8rpx;font-weight:700}
.rd-section{margin:18rpx 24rpx;background:var(--card);border-radius:22rpx;padding:24rpx;box-shadow:var(--shadow);border:1rpx solid rgba(232,225,212,0.75)}
.rd-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:16rpx}
.rd-bio{font-size:26rpx;color:var(--text-secondary);line-height:1.85}
.rd-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}
.rd-stat{background:#f4eee3;border-radius:18rpx;padding:18rpx 8rpx;text-align:center}
.rd-stat text:first-child{display:block;font-size:34rpx;font-weight:900;color:var(--primary)}
.rd-stat text:last-child{display:block;font-size:20rpx;color:var(--text-light);margin-top:3rpx}
.rd-section-title{font-size:29rpx;font-weight:900;color:var(--text);padding-left:18rpx;position:relative;margin-bottom:16rpx}
.rd-section-title::before{content:'';position:absolute;left:0;top:9rpx;width:7rpx;height:24rpx;border-radius:8rpx;background:var(--accent)}
.rd-highlight{font-size:25rpx;color:var(--text-secondary);line-height:1.7;padding:10rpx 0;border-bottom:1rpx solid var(--border-light)}
.rd-highlight:last-child{border-bottom:0}
.rd-gallery{display:grid;grid-template-columns:1.15fr .85fr;gap:10rpx}
.rd-gallery-img{height:170rpx;border-radius:18rpx}
.rd-gallery-img:first-child{height:350rpx;grid-row:span 2}
.rd-contact{display:flex;align-items:center;gap:16rpx;background:rgba(31,107,82,0.06);border-radius:18rpx;padding:18rpx;border:1rpx solid rgba(31,107,82,0.12)}
.rd-contact>view{flex:1}
.rd-wechat{font-size:30rpx;font-weight:900;color:var(--primary)}
.rd-contact-note{font-size:22rpx;line-height:1.55;color:var(--text-light);margin-top:5rpx}
.rd-copy{border:0;background:var(--primary);color:#fff;border-radius:999rpx;font-size:24rpx;font-weight:900;padding:0 24rpx;height:64rpx;line-height:64rpx}
