.detail-page { background: var(--bg); padding-bottom: 120rpx; }
.detail-hero { position: relative; height: 440rpx; }
.detail-cover { width: 100%; height: 100%; }
.detail-hero-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 60rpx 24rpx 24rpx; background: linear-gradient(transparent, rgba(0,0,0,0.65)); }
.detail-status { margin-bottom: 12rpx; }
.detail-title-hero { font-size: 36rpx; font-weight: 700; color: white; line-height: 1.3; }

.detail-section { margin: 16rpx 20rpx; background: var(--white); border-radius: var(--radius-lg); padding: 24rpx; box-shadow: var(--shadow); }
.detail-spots-row { margin-bottom: 20rpx; }
.detail-spots-num { font-size: 48rpx; font-weight: 700; color: var(--primary); }
.detail-spots-label { font-size: 26rpx; color: var(--text-secondary); }
.detail-info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 16rpx; }
.detail-info-item { display: flex; align-items: center; gap: 12rpx; padding: 16rpx; background: var(--bg); border-radius: var(--radius); }
.detail-info-icon { font-size: 32rpx; }
.detail-info-value { font-size: 24rpx; font-weight: 600; }
.detail-info-label { font-size: 20rpx; color: var(--text-light); }
.detail-tags { margin-top: 8rpx; }
.detail-section-title { font-size: 30rpx; font-weight: 700; margin-bottom: 16rpx; }
.detail-text { font-size: 26rpx; color: var(--text-secondary); line-height: 1.8; }
.detail-list-item { font-size: 24rpx; color: var(--text-secondary); padding: 4rpx 0; }

.leader-card { display: flex; align-items: center; gap: 16rpx; margin-bottom: 20rpx; }
.leader-name { font-size: 28rpx; font-weight: 600; }
.leader-tag { font-size: 22rpx; color: var(--secondary); margin-top: 2rpx; }
.leader-contact-card { background: rgba(47,167,161,0.06); border-radius: var(--radius); padding: 20rpx; border: 2rpx solid rgba(47,167,161,0.15); }
.leader-contact-label { font-size: 26rpx; font-weight: 600; color: var(--secondary); margin-bottom: 12rpx; }
.leader-contact-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10rpx; }
.leader-wechat { font-size: 28rpx; font-weight: 600; color: var(--text); }
.leader-contact-hint { font-size: 22rpx; color: var(--text-light); }

.participants-row { padding: 8rpx 0; }
.participants-more { width: 56rpx; height: 56rpx; border-radius: 50%; background: var(--bg); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: var(--text-secondary); }

.photo-scroll { display: flex; gap: 12rpx; overflow-x: auto; }
.photo-scroll-item { width: 280rpx; height: 200rpx; border-radius: var(--radius); flex-shrink: 0; }

.detail-bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; gap: 16rpx; padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.95); backdrop-filter: blur(20rpx); border-top: 1rpx solid var(--border); z-index: 100; }
.detail-finished-tip { flex: 1; text-align: center; font-size: 26rpx; color: var(--text-light); padding: 12rpx 0; }