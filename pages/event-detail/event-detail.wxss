.ed-page{background:var(--bg);padding-bottom:120rpx}
.ed-hero{position:relative;height:400rpx}
.ed-cover{width:100%;height:100%}
.ed-hero-overlay{position:absolute;bottom:0;left:0;right:0;padding:60rpx 24rpx 24rpx;background:linear-gradient(transparent,rgba(0,0,0,0.65))}
.ed-title-hero{font-size:34rpx;font-weight:700;color:#fff;line-height:1.3}

.detail-section{margin:14rpx 20rpx;background:var(--card);border-radius:var(--radius-lg);padding:22rpx 24rpx;box-shadow:var(--shadow)}
.detail-title{font-size:26rpx;font-weight:700;margin-bottom:12rpx;color:var(--text)}
.detail-text{font-size:26rpx;color:var(--text-secondary);line-height:1.8}
.ed-spots{font-size:42rpx;font-weight:700;color:var(--text);margin-bottom:16rpx}
.ed-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10rpx;margin-bottom:14rpx}
.ed-info{display:flex;align-items:center;gap:10rpx;padding:14rpx;background:var(--bg);border-radius:var(--radius)}
.ed-info-icon{font-size:28rpx}
.ed-info-v{font-size:24rpx;font-weight:600}
.ed-info-l{font-size:20rpx;color:var(--text-light)}

.leader-contact{background:rgba(45,111,247,0.04);border-radius:var(--radius);padding:18rpx;margin-top:16rpx;border:2rpx solid rgba(45,111,247,0.08)}
.photo-scroll{display:flex;gap:10rpx}
.photo-scroll-item{width:260rpx;height:180rpx;border-radius:var(--radius);flex-shrink:0}

.ed-bar{position:fixed;bottom:0;left:0;right:0;display:flex;align-items:center;gap:14rpx;padding:10rpx 24rpx calc(10rpx + env(safe-area-inset-bottom));background:rgba(255,255,255,0.95);backdrop-filter:blur(20rpx);border-top:1rpx solid var(--border-light);z-index:100}
.ed-bar-text{font-size:24rpx;color:var(--text-secondary);flex-shrink:0}
