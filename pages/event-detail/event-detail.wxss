.ed-page{background:var(--bg);padding-bottom:120rpx}
.ed-hero{position:relative;height:460rpx;background:#D8D1C2}
.ed-cover{width:100%;height:100%}
.ed-hero-overlay{position:absolute;bottom:0;left:0;right:0;padding:96rpx 28rpx 30rpx;background:linear-gradient(180deg,rgba(0,0,0,0),rgba(15,23,18,0.78))}
.ed-status{margin-bottom:14rpx;display:inline-block;background:rgba(255,253,248,0.92)}
.ed-title-hero{font-size:40rpx;font-weight:800;color:#fff;line-height:1.25}
.ed-hero-meta{font-size:24rpx;color:rgba(255,255,255,0.82);margin-top:10rpx}

.detail-section{margin:16rpx 22rpx;background:var(--card);border-radius:20rpx;padding:24rpx 26rpx;box-shadow:var(--shadow);border:1rpx solid rgba(232,225,212,0.72)}
.detail-title{font-size:28rpx;font-weight:800;margin-bottom:14rpx;color:var(--text);position:relative;padding-left:18rpx}
.detail-title::before{content:'';position:absolute;left:0;top:11rpx;width:7rpx;height:22rpx;border-radius:8rpx;background:var(--accent)}
.detail-text{font-size:26rpx;color:var(--text-secondary);line-height:1.8}
.ed-spots{font-size:42rpx;font-weight:700;color:var(--text);margin-bottom:16rpx}
.ed-info-grid{display:grid;grid-template-columns:1fr 1fr;gap:10rpx;margin-bottom:14rpx}
.ed-info{display:flex;align-items:center;gap:12rpx;padding:16rpx;background:#F4EFE5;border-radius:var(--radius)}
.ed-info-mark{width:10rpx;height:34rpx;border-radius:8rpx;background:linear-gradient(180deg,var(--primary),var(--accent))}
.ed-info-v{font-size:24rpx;font-weight:600}
.ed-info-l{font-size:20rpx;color:var(--text-light)}
.ed-include{display:inline-block;margin:0 10rpx 10rpx 0;padding:9rpx 16rpx;border-radius:999rpx;background:rgba(31,107,82,0.08);color:var(--primary);font-size:24rpx;font-weight:600}

.leader-contact{background:rgba(31,107,82,0.06);border-radius:var(--radius);padding:18rpx;margin-top:16rpx;border:2rpx solid rgba(31,107,82,0.1)}
.photo-scroll{display:flex;gap:10rpx}
.photo-scroll-item{width:280rpx;height:190rpx;border-radius:var(--radius);flex-shrink:0;margin-right:12rpx}

.ed-bar{position:fixed;bottom:0;left:0;right:0;display:flex;align-items:center;gap:14rpx;padding:12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));background:rgba(255,253,248,0.96);backdrop-filter:blur(20rpx);border-top:1rpx solid var(--border-light);z-index:100}
.ed-bar-text{font-size:24rpx;color:var(--text-secondary);flex-shrink:0}
.story-face-more{border-radius:50%;background:var(--border);color:var(--text-secondary);display:flex;align-items:center;justify-content:center;border:2rpx solid var(--card)}
