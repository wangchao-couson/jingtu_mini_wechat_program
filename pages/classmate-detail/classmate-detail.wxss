.cd-page { background: var(--bg); padding-bottom: 40rpx; }

.cd-hero {
  padding: 40rpx 32rpx 32rpx;
  text-align: center;
  color: white;
}
.cd-avatar { margin: 0 auto 16rpx; }
.cd-name { font-size: 36rpx; font-weight: 700; margin-bottom: 4rpx; }
.cd-city { font-size: 24rpx; opacity: 0.8; margin-bottom: 12rpx; }
.cd-bio-hero { font-size: 26rpx; opacity: 0.85; font-style: italic; }

.detail-section {
  margin: 16rpx 20rpx;
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow);
}
.detail-section-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.cd-stats-grid {
  display: flex;
  gap: 16rpx;
}
.cd-stat {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: var(--bg);
  border-radius: var(--radius);
}
.cd-stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}
.cd-stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.cd-contact-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 4rpx;
}
.cd-contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.cd-contact-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--secondary);
}

.cd-actions {
  padding: 16rpx 24rpx;
  display: flex;
  gap: 16rpx;
}