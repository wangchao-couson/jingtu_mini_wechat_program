.cd-page{background:radial-gradient(circle at 20% 0,rgba(53,208,127,.12),transparent 36%),var(--bg-main);padding-bottom:40rpx;min-height:100vh;color:#fff}
.cd-hero{background:linear-gradient(180deg,rgba(53,208,127,.18),rgba(255,255,255,.04));padding:52rpx 32rpx 36rpx;text-align:center;color:#fff;border-bottom:1rpx solid var(--line-soft)}
.cd-name{font-size:34rpx;font-weight:700;margin-top:12rpx}
.cd-city{font-size:24rpx;opacity:0.75;margin:4rpx 0 10rpx}
.cd-role{display:inline-block;margin:2rpx 0 12rpx;padding:7rpx 16rpx;border-radius:999rpx;background:rgba(53,208,127,.14);color:var(--green-main);font-size:22rpx;font-weight:900}
.cd-bio-hero{font-size:26rpx;opacity:0.85}

.detail-section{margin:14rpx 20rpx;background:var(--bg-card);border:1rpx solid var(--line-soft);border-radius:var(--radius-lg);padding:22rpx 24rpx;box-shadow:var(--shadow)}
.detail-title,.detail-section-title{font-size:26rpx;font-weight:700;margin-bottom:12rpx;color:var(--text)}
.cd-stats-grid{display:flex;gap:12rpx}
.cd-stat{flex:1;text-align:center;padding:18rpx;background:rgba(255,255,255,.08);border-radius:var(--radius);border:1rpx solid var(--line-soft)}
.cd-stat-num{display:block;font-size:38rpx;font-weight:700;color:var(--primary)}
.cd-stat-label{font-size:20rpx;color:var(--text-light);margin-top:4rpx}
.cd-contribution{display:flex;align-items:flex-start;gap:12rpx;margin-top:16rpx}
.cd-dot{width:10rpx;height:10rpx;border-radius:50%;background:var(--accent);margin-top:15rpx;box-shadow:0 0 16rpx rgba(230,161,92,.34)}
.cd-contribution-text{flex:1;font-size:25rpx;line-height:1.65;color:var(--text-sub)}
.cd-chip{display:inline-block;margin:0 10rpx 10rpx 0;padding:9rpx 16rpx;border-radius:999rpx;background:rgba(255,255,255,.08);border:1rpx solid var(--line-soft);font-size:24rpx;color:var(--text-sub)}
.cd-contact-people{display:flex;align-items:center;gap:10rpx;flex-wrap:wrap}
.cd-person{width:48rpx;height:48rpx;border-radius:50%;background:linear-gradient(135deg,var(--green-main),var(--blue-soft));display:flex;align-items:center;justify-content:center;font-size:20rpx;font-weight:900;color:#fff;border:1rpx solid rgba(255,255,255,.22)}
.cd-person-text{font-size:24rpx;color:var(--text-sub);margin-left:4rpx}

.cd-contact-label{font-size:22rpx;color:var(--text-light);margin-bottom:4rpx}
.cd-contact-tip{font-size:24rpx;color:var(--text-sub);line-height:1.6;margin-bottom:14rpx}
.cd-contact-row{display:flex;align-items:center;justify-content:space-between}
.cd-contact-value{font-size:28rpx;font-weight:600;color:var(--primary)}
.cd-actions{padding:16rpx 24rpx;display:flex;gap:16rpx}
