.cm-page{padding-bottom:40rpx;background:radial-gradient(circle at 20% 0,rgba(53,208,127,.12),transparent 36%),var(--bg-main);min-height:100vh;color:#fff}
.we-hero{padding:32rpx 28rpx 12rpx}
.we-title{font-size:58rpx;font-weight:900;line-height:1.1;color:var(--text);margin-top:8rpx}
.we-sub{font-size:26rpx;color:var(--text-secondary);margin-top:8rpx;line-height:1.6}
.network-card{height:500rpx;margin:18rpx 24rpx;background:var(--bg-card);border:1rpx solid var(--line-soft);border-radius:28rpx;position:relative;overflow:hidden;box-shadow:var(--shadow-md);backdrop-filter:blur(20rpx)}
.network-head{position:absolute;left:22rpx;right:22rpx;top:20rpx;z-index:2}
.network-title{font-size:30rpx;font-weight:900}
.network-sub{font-size:22rpx;color:var(--text-sub);margin-top:4rpx}
.network-line{position:absolute;height:2rpx;background:rgba(46,94,78,.22);transform-origin:left center}
.line-a{width:390rpx;left:130rpx;top:150rpx;transform:rotate(12deg)}
.line-b{width:330rpx;left:145rpx;top:205rpx;transform:rotate(-28deg)}
.line-c{width:300rpx;left:230rpx;top:120rpx;transform:rotate(50deg)}
.network-node{position:absolute;transform:translate(-50%,-50%);text-align:center}
.network-dot{width:62rpx;height:62rpx;border-radius:50%;background:linear-gradient(135deg,var(--green-dark),var(--blue-soft));color:#fff;display:flex;align-items:center;justify-content:center;font-size:24rpx;font-weight:900;margin:0 auto;box-shadow:0 10rpx 24rpx rgba(0,0,0,.28);border:1rpx solid rgba(255,255,255,.24)}
.network-name{font-size:22rpx;font-weight:900;margin-top:6rpx;color:var(--text)}
.network-role{font-size:18rpx;color:var(--text-light)}
.legend{position:absolute;left:22rpx;right:22rpx;bottom:18rpx;color:var(--text-weak);font-size:20rpx}
.people-head{display:flex;align-items:flex-end;justify-content:space-between;padding:28rpx 24rpx 16rpx}
.people-title{font-size:34rpx;font-weight:900}
.people-sub{font-size:23rpx;color:var(--text-sub);margin-top:4rpx}
.people-more{font-size:22rpx;color:var(--green-main);font-weight:800}
.people-scroll{white-space:nowrap;padding-left:24rpx}
.person-card{display:inline-block;width:280rpx;height:420rpx;margin-right:18rpx;border-radius:24rpx;overflow:hidden;position:relative;background:#111;border:1rpx solid var(--line-soft);box-shadow:var(--shadow)}
.person-cover{width:100%;height:100%}
.person-mask{position:absolute;left:0;right:0;top:0;bottom:0;background:linear-gradient(180deg,rgba(0,0,0,.08),rgba(0,0,0,.74))}
.person-copy{position:absolute;left:18rpx;right:18rpx;bottom:18rpx;color:#fff}
.person-name{font-size:30rpx;font-weight:900}
.person-role{font-size:22rpx;color:var(--green-main);font-weight:800;margin-top:4rpx}
.person-desc{font-size:21rpx;color:var(--text-sub);line-height:1.45;margin-top:8rpx;white-space:normal}
.compact{opacity:.78}
.cm-header{padding:20rpx 24rpx 0}
.cm-search-box{display:flex;align-items:center;background:var(--card);border-radius:28rpx;padding:12rpx 18rpx;box-shadow:var(--shadow)}
.cm-search-icon{font-size:28rpx;margin-right:12rpx}
.cm-search-input{flex:1;font-size:26rpx}
.cm-count{text-align:center;font-size:24rpx;color:var(--text-secondary);margin:14rpx 0 6rpx}

.tag-scroll{width:100%}
.tag-row{display:flex;gap:10rpx;padding:8rpx 24rpx}
.tag-chip{padding:8rpx 20rpx;border-radius:20rpx;font-size:24rpx;white-space:nowrap;background:var(--card);color:var(--text-secondary);border:2rpx solid var(--border);transition:all .2s}
.tag-chip.active{background:var(--primary);color:#fff;border-color:var(--primary);box-shadow:0 3rpx 10rpx rgba(45,111,247,0.2)}

.cm-list{padding:8rpx 24rpx}
.cm-list-head{padding:28rpx 24rpx 10rpx}
.cm-card{display:flex;align-items:center;gap:18rpx;background:var(--card);border-radius:var(--radius-lg);padding:20rpx 22rpx;margin-bottom:12rpx;box-shadow:var(--shadow);position:relative}
.cm-card.has-common{border-left:4rpx solid var(--accent)}
.cm-info{flex:1;min-width:0}
.cm-name{font-size:28rpx;font-weight:600;margin-bottom:2rpx}
.cm-city{font-size:24rpx;font-weight:400;color:var(--text-light)}
.cm-bio{font-size:24rpx;color:var(--text-secondary);margin-bottom:8rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cm-tags{margin-bottom:6rpx}
.cm-stats{font-size:22rpx;color:var(--text-light)}
.cm-common{color:var(--accent);font-weight:500}
.cm-arrow{font-size:26rpx;color:var(--text-light)}
